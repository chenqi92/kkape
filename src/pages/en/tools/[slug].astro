---
import Layout from '@layouts/Layout.astro';
import ToolCard from '@components/ToolCard.astro';
import ImageGallery from '@components/ImageGallery.astro';
import { tools, getToolBySlug, getRelatedTools } from '@data/tools';
import { useTranslations } from '@i18n/index';
import { getDemoImages } from '@data/demoImages';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  return tools.map((tool) => ({
    params: { slug: tool.slug },
  }));
}

const { slug } = Astro.params;
const tool = getToolBySlug(slug as string);

if (!tool) {
  return Astro.redirect('/404');
}

const lang = 'en';
const t = useTranslations(lang);
const relatedTools = getRelatedTools(tool.id);

const autoDemoImages = getDemoImages(tool.slug);
const demoGalleryImages = autoDemoImages.length > 0
  ? autoDemoImages.map((src, i) => ({ src, caption: `${tool.name[lang]} - ${i + 1}` }))
  : (tool.demoImages?.map(img => ({ src: img.src, caption: img.caption[lang] })) || []);

const categoryLabels: Record<string, string> = {
  desktop: 'Desktop',
  library: 'Library',
  web: 'Web App',
  plugin: 'Plugin',
  mobile: 'Mobile',
};

const iconGradients: Record<string, string> = {
  chart: 'from-cyan-500 to-cyan-600',
  wrench: 'from-sky-500 to-sky-600',
  table: 'from-emerald-500 to-emerald-600',
  flask: 'from-amber-500 to-amber-600',
  server: 'from-rose-500 to-rose-600',
};

const gradClass = iconGradients[tool.icon || ''] || 'from-gray-500 to-gray-600';

const iconExts = ['.png', '.jpg', '.jpeg', '.svg', '.webp', '.ico'];
const customIcon = iconExts
  .map(ext => ({ ext, file: path.resolve('public', 'images', 'tools', 'icons', `${tool.slug}${ext}`) }))
  .find(({ file }) => fs.existsSync(file));
const customIconSrc = customIcon ? `/images/tools/icons/${tool.slug}${customIcon.ext}` : null;
---

<Layout title={tool.name[lang]} description={tool.description[lang]}>
  <article class="relative">
    <!-- ============ HERO HEADER ============ -->
    <section class="relative py-20 overflow-hidden">
      <div class="absolute inset-0 detail-grid opacity-[0.02] dark:opacity-[0.05] pointer-events-none"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-primary-500/5 dark:bg-primary-500/10 rounded-full blur-[100px] pointer-events-none"></div>
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-primary-500/30 to-transparent"></div>

      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl relative z-10">
        <nav class="mb-8 flex items-center gap-2 text-sm">
          <a href="/en/" class="text-[rgb(var(--color-text-secondary))] hover:text-primary-500 transition-colors">Home</a>
          <svg class="w-3.5 h-3.5 text-[rgb(var(--color-text-secondary))] opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          <a href="/en/#tools" class="text-[rgb(var(--color-text-secondary))] hover:text-primary-500 transition-colors">Tools</a>
          <svg class="w-3.5 h-3.5 text-[rgb(var(--color-text-secondary))] opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
          <span class="text-[rgb(var(--color-text-primary))] font-medium">{tool.name[lang]}</span>
        </nav>

        <div class="flex flex-col sm:flex-row items-start gap-6">
          {customIconSrc ? (
            <div class="w-16 h-16 rounded-2xl overflow-hidden shadow-xl flex-shrink-0">
              <img src={customIconSrc} alt={tool.name[lang]} class="w-full h-full object-cover" />
            </div>
          ) : (
          <div class="w-16 h-16 rounded-2xl overflow-hidden shadow-xl flex-shrink-0">
            <img src="/images/tools/icons/default-lib-icon.svg" alt={tool.name[lang]} class="w-full h-full object-cover" />
          </div>
          )}
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-2">
              <span class="px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider bg-primary-500/10 text-primary-500 border border-primary-500/20">{categoryLabels[tool.category]}</span>
            </div>
            <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-[rgb(var(--color-text-primary))] tracking-tight mb-2">{tool.name[lang]}</h1>
            <p class="text-lg text-primary-500 font-mono mb-4">{tool.tagline[lang]}</p>
            <p class="text-[rgb(var(--color-text-secondary))] leading-relaxed max-w-2xl">{tool.description[lang]}</p>
          </div>
        </div>

        <div class="mt-8 flex flex-wrap gap-3">
          {tool.links.website && (
            <a href={tool.links.website} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-semibold bg-primary-500 text-white hover:bg-primary-400 transition-all shadow-lg shadow-primary-500/20">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
              {t('tools.demo')}
            </a>
          )}
          {tool.links.github && (
            <a href={tool.links.github} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-semibold border border-[rgb(var(--color-border))] hover:border-primary-500/40 transition-all text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-text-primary))]">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"></path></svg>
              {t('tools.github')}
            </a>
          )}
          {tool.links.download && (
            <a href={tool.links.download} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-semibold border border-[rgb(var(--color-border))] hover:border-primary-500/40 transition-all text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-text-primary))]">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path></svg>
              {t('tools.download')}
            </a>
          )}
          {tool.links.docs && (
            <a href={tool.links.docs} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-semibold border border-[rgb(var(--color-border))] hover:border-primary-500/40 transition-all text-[rgb(var(--color-text-secondary))] hover:text-[rgb(var(--color-text-primary))]">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path></svg>
              {t('tools.documentation')}
            </a>
          )}
          {demoGalleryImages.length > 0 && (
            <ImageGallery
              images={demoGalleryImages}
              buttonText="Feature Demo"
              toolName={tool.name[lang]}
            />
          )}
        </div>

        <div class="mt-6 flex flex-wrap items-center gap-2">
          <span class="text-xs text-[rgb(var(--color-text-secondary))] uppercase tracking-wider mr-1">Tech Stack:</span>
          {tool.techStack.map(tech => (
            <span class="px-3 py-1 rounded-lg border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-secondary))] text-xs font-mono text-[rgb(var(--color-text-secondary))]">{tech}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ SCREENSHOTS ============ -->
    <section class="py-16 relative">
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[rgb(var(--color-border))] to-transparent"></div>
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-1 h-6 bg-sky-500 rounded-full"></div>
          <h2 class="text-xl font-bold text-[rgb(var(--color-text-primary))] tracking-tight">Screenshots</h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {(tool.screenshots && tool.screenshots.length > 0 ? tool.screenshots : ['/images/tools/placeholder.svg']).map((src, i) => (
            <div class="scroll-reveal rounded-2xl border border-[rgb(var(--color-border))] overflow-hidden bg-[rgb(var(--color-bg-secondary))] group cursor-pointer" style={`--reveal-delay: ${i * 0.1}s`}>
              <div class="aspect-[16/9] overflow-hidden">
                <img
                  src={src}
                  alt={`${tool.name[lang]} screenshot ${i + 1}`}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                  onerror="this.onerror=null;this.src='/images/tools/placeholder.svg'"
                />
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ FEATURES ============ -->
    <section class="py-16 relative">
      <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[rgb(var(--color-border))] to-transparent"></div>
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-1 h-6 bg-primary-500 rounded-full"></div>
          <h2 class="text-xl font-bold text-[rgb(var(--color-text-primary))] tracking-tight">{t('detail.features')}</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {tool.features[lang].map((feature, i) => (
            <div class="scroll-reveal flex items-start gap-3 p-4 rounded-xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-card))] hover:border-primary-500/30 transition-all" style={`--reveal-delay: ${i * 0.05}s`}>
              <span class="w-6 h-6 rounded-lg bg-primary-500/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3.5 h-3.5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"></path></svg>
              </span>
              <span class="text-sm text-[rgb(var(--color-text-secondary))] leading-relaxed">{feature}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ INSTALLATION ============ -->
    {tool.installation && (
      <section class="py-16 relative">
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[rgb(var(--color-border))] to-transparent"></div>
        <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-1 h-6 bg-emerald-500 rounded-full"></div>
            <h2 class="text-xl font-bold text-[rgb(var(--color-text-primary))] tracking-tight">{t('detail.installation')}</h2>
          </div>
          <div class="rounded-2xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg-secondary))] overflow-hidden">
            <div class="flex items-center gap-2 px-4 py-3 border-b border-[rgb(var(--color-border))]">
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-red-500/60"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/60"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-green-500/60"></div>
              </div>
              <span class="text-[10px] font-mono text-[rgb(var(--color-text-secondary))] ml-2">installation</span>
            </div>
            <pre class="p-5 text-sm font-mono text-[rgb(var(--color-text-secondary))] leading-relaxed overflow-x-auto whitespace-pre-wrap">{tool.installation[lang]}</pre>
          </div>
        </div>
      </section>
    )}

    <!-- ============ DEMO ============ -->
    {tool.demo && (
      <section class="py-16 relative">
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[rgb(var(--color-border))] to-transparent"></div>
        <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-1 h-6 bg-amber-500 rounded-full"></div>
            <h2 class="text-xl font-bold text-[rgb(var(--color-text-primary))] tracking-tight">{t('detail.demo')}</h2>
          </div>
          <div class="rounded-2xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-card))] p-8">
            {tool.demo.type === 'interactive' && tool.demo.url && (
              <div class="text-center">
                <p class="text-[rgb(var(--color-text-secondary))] mb-6">{tool.demo.description?.[lang]}</p>
                <a href={tool.demo.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-8 py-3 rounded-xl text-sm font-semibold bg-primary-500 text-white hover:bg-primary-400 transition-all shadow-lg shadow-primary-500/20">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                  Live Demo
                </a>
              </div>
            )}
            {tool.demo.type === 'video' && tool.demo.url && (
              <div class="aspect-video rounded-xl overflow-hidden">
                <iframe src={tool.demo.url} class="w-full h-full" allowfullscreen></iframe>
              </div>
            )}
            {tool.demo.type === 'images' && (
              <div class="text-center">
                <p class="text-[rgb(var(--color-text-secondary))]">{tool.demo.description?.[lang]}</p>
              </div>
            )}
          </div>
        </div>
      </section>
    )}

    <!-- ============ RELATED ============ -->
    {relatedTools.length > 0 && (
      <section class="py-16 relative">
        <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-[rgb(var(--color-border))] to-transparent"></div>
        <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-1 h-6 bg-primary-500 rounded-full"></div>
            <h2 class="text-xl font-bold text-[rgb(var(--color-text-primary))] tracking-tight">{t('detail.relatedTools')}</h2>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            {relatedTools.map(relatedTool => (
              <ToolCard tool={relatedTool} lang={lang} />
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- ============ BACK ============ -->
    <section class="py-8">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-5xl">
        <a href="/en/" class="inline-flex items-center gap-2 text-sm font-medium text-[rgb(var(--color-text-secondary))] hover:text-primary-500 transition-colors">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
          Back to Home
        </a>
      </div>
    </section>
  </article>
</Layout>

<style is:global>
  .detail-grid {
    background-image:
      linear-gradient(rgba(6,182,212,0.5) 1px, transparent 1px),
      linear-gradient(90deg, rgba(6,182,212,0.5) 1px, transparent 1px);
    background-size: 48px 48px;
  }
  .scroll-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: var(--reveal-delay, 0s);
  }
  .scroll-reveal.revealed {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const reveals = document.querySelectorAll('.scroll-reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) entry.target.classList.add('revealed');
    });
  }, { threshold: 0.1 });
  reveals.forEach(el => observer.observe(el));
</script>
