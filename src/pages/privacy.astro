---
import Layout from '@layouts/Layout.astro';
import { getLangFromUrl, useTranslations } from '@i18n/index';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isZh = lang === 'zh';
---

<Layout>
  <section class="py-20">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 max-w-3xl">
      <h1 class="text-4xl font-bold text-[rgb(var(--color-text-primary))] mb-8">
        {isZh ? '隐私政策' : 'Privacy Policy'}
      </h1>
      <p class="text-sm text-[rgb(var(--color-text-secondary))] mb-12">
        {isZh ? '最后更新：2026 年 3 月 3 日' : 'Last updated: March 3, 2026'}
      </p>

      <div class="prose dark:prose-invert max-w-none space-y-8">
        <!-- Introduction -->
        <div>
          <h2 class="text-2xl font-semibold text-[rgb(var(--color-text-primary))] mb-4">
            {isZh ? '概述' : 'Introduction'}
          </h2>
          <p class="text-[rgb(var(--color-text-secondary))] leading-relaxed">
            {isZh
              ? 'kknas（以下简称"本应用"）是由 kkape 开发的 NAS 文件与媒体管理应用。我们非常重视用户的隐私保护，本隐私政策说明了我们如何收集、使用和保护您的信息。'
              : 'kknas (hereinafter referred to as "the App") is a NAS file and media management application developed by kkape. We take your privacy seriously. This Privacy Policy explains how we collect, use, and protect your information.'}
          </p>
        </div>

        <!-- Data Collection -->
        <div>
          <h2 class="text-2xl font-semibold text-[rgb(var(--color-text-primary))] mb-4">
            {isZh ? '信息收集' : 'Information Collection'}
          </h2>
          <p class="text-[rgb(var(--color-text-secondary))] leading-relaxed mb-4">
            {isZh
              ? '本应用不会收集、存储或传输您的任何个人数据到外部服务器。所有数据均存储在您的设备本地。'
              : 'The App does not collect, store, or transmit any of your personal data to external servers. All data is stored locally on your device.'}
          </p>
          <ul class="list-disc list-inside text-[rgb(var(--color-text-secondary))] space-y-2">
            <li>{isZh ? 'NAS 连接信息（地址、凭据）仅存储在设备本地' : 'NAS connection information (address, credentials) is stored locally on device only'}</li>
            <li>{isZh ? '不使用第三方分析或追踪服务' : 'No third-party analytics or tracking services are used'}</li>
            <li>{isZh ? '不包含广告' : 'No advertisements are included'}</li>
          </ul>
        </div>

        <!-- Permissions -->
        <div>
          <h2 class="text-2xl font-semibold text-[rgb(var(--color-text-primary))] mb-4">
            {isZh ? '权限使用说明' : 'Permission Usage'}
          </h2>
          <div class="space-y-4">
            <div class="p-4 rounded-lg bg-[rgb(var(--color-bg-secondary))]">
              <h3 class="font-medium text-[rgb(var(--color-text-primary))] mb-1">{isZh ? '局域网访问' : 'Local Network Access'}</h3>
              <p class="text-sm text-[rgb(var(--color-text-secondary))]">{isZh ? '用于发现和连接局域网内的 NAS 设备。' : 'Used to discover and connect to NAS devices on the local network.'}</p>
            </div>
            <div class="p-4 rounded-lg bg-[rgb(var(--color-bg-secondary))]">
              <h3 class="font-medium text-[rgb(var(--color-text-primary))] mb-1">{isZh ? '相册访问' : 'Photo Library Access'}</h3>
              <p class="text-sm text-[rgb(var(--color-text-secondary))]">{isZh ? '用于浏览和保存照片、视频到本地相册。' : 'Used to browse and save photos/videos to the local photo library.'}</p>
            </div>
            <div class="p-4 rounded-lg bg-[rgb(var(--color-bg-secondary))]">
              <h3 class="font-medium text-[rgb(var(--color-text-primary))] mb-1">{isZh ? '音乐库访问' : 'Music Library Access'}</h3>
              <p class="text-sm text-[rgb(var(--color-text-secondary))]">{isZh ? '用于浏览和播放本地音乐。' : 'Used to browse and play local music.'}</p>
            </div>
            <div class="p-4 rounded-lg bg-[rgb(var(--color-bg-secondary))]">
              <h3 class="font-medium text-[rgb(var(--color-text-primary))] mb-1">{isZh ? '相机与麦克风' : 'Camera & Microphone'}</h3>
              <p class="text-sm text-[rgb(var(--color-text-secondary))]">{isZh ? '用于扫描二维码和语音搜索功能。' : 'Used for QR code scanning and voice search functionality.'}</p>
            </div>
          </div>
        </div>

        <!-- Data Security -->
        <div>
          <h2 class="text-2xl font-semibold text-[rgb(var(--color-text-primary))] mb-4">
            {isZh ? '数据安全' : 'Data Security'}
          </h2>
          <p class="text-[rgb(var(--color-text-secondary))] leading-relaxed">
            {isZh
              ? '您的 NAS 登录凭据使用 iOS/macOS 系统 Keychain 安全存储，应用与 NAS 之间的通信支持 HTTPS/SFTP 等加密协议。我们不会以任何方式访问您的数据。'
              : 'Your NAS login credentials are securely stored using the iOS/macOS system Keychain. Communication between the app and your NAS supports encrypted protocols such as HTTPS/SFTP. We do not access your data in any way.'}
          </p>
        </div>

        <!-- Contact -->
        <div>
          <h2 class="text-2xl font-semibold text-[rgb(var(--color-text-primary))] mb-4">
            {isZh ? '联系我们' : 'Contact Us'}
          </h2>
          <p class="text-[rgb(var(--color-text-secondary))] leading-relaxed">
            {isZh
              ? '如果您对本隐私政策有任何疑问，请通过以下方式联系我们：'
              : 'If you have any questions about this Privacy Policy, please contact us:'}
          </p>
          <p class="text-[rgb(var(--color-text-secondary))] mt-2">
            Email: <a href="mailto:syq19700102@icloud.com" class="text-primary-500 hover:underline">syq19700102@icloud.com</a>
          </p>
        </div>

        <!-- Changes -->
        <div>
          <h2 class="text-2xl font-semibold text-[rgb(var(--color-text-primary))] mb-4">
            {isZh ? '政策更新' : 'Policy Updates'}
          </h2>
          <p class="text-[rgb(var(--color-text-secondary))] leading-relaxed">
            {isZh
              ? '我们可能会不时更新本隐私政策。更新后的政策将在本页面发布，并更新"最后更新"日期。'
              : 'We may update this Privacy Policy from time to time. Updated policies will be posted on this page with an updated "Last Updated" date.'}
          </p>
        </div>
      </div>

      <div class="mt-12 pt-8 border-t border-[rgb(var(--color-bg-secondary))]">
        <a href="/" class="text-primary-500 hover:underline">
          {isZh ? '← 返回首页' : '← Back to Home'}
        </a>
      </div>
    </div>
  </section>
</Layout>
