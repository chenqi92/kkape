---
interface Props {
  images: { src: string; caption: string }[];
  buttonText: string;
  toolName: string;
  compact?: boolean;
}

const { images, buttonText, toolName, compact = false } = Astro.props;
const galleryId = `gallery-${toolName.toLowerCase().replace(/\s+/g, '-')}-${Math.random().toString(36).slice(2, 8)}`;
---

{images.length > 0 && (
  <div class="inline-flex">
    <!-- Trigger Button -->
    {compact ? (
      <button
        data-gallery-trigger={galleryId}
        class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[10px] font-semibold bg-primary-500/10 text-primary-500 hover:bg-primary-500/20 border border-primary-500/20 transition-all cursor-pointer whitespace-nowrap"
      >
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
        {buttonText}
      </button>
    ) : (
      <button
        data-gallery-trigger={galleryId}
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl text-sm font-semibold border border-primary-500/30 bg-primary-500/5 text-primary-500 hover:bg-primary-500/10 hover:border-primary-500/50 transition-all cursor-pointer"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
        </svg>
        {buttonText}
        <span class="text-xs opacity-60 font-mono">({images.length})</span>
      </button>
    )}

    <!-- Lightbox Modal -->
    <div
      id={galleryId}
      class="gallery-modal fixed inset-0 z-[9999] hidden items-center justify-center"
      style="background: rgba(0,0,0,0.92); backdrop-filter: blur(8px);"
    >
      <!-- Top bar -->
      <div class="absolute top-0 left-0 right-0 z-50 flex items-center justify-between px-4 py-3">
        <!-- Counter -->
        <div class="px-3 py-1.5 rounded-lg bg-white/10 text-white text-xs font-mono">
          <span data-gallery-current>1</span> / {images.length}
        </div>
        <!-- Tool name -->
        <div class="px-4 py-1.5 rounded-lg bg-white/10 text-white text-sm font-semibold">
          {toolName}
        </div>
        <!-- Close X -->
        <button data-gallery-close class="w-10 h-10 rounded-xl bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <!-- Prev button -->
      {images.length > 1 && (
        <button data-gallery-prev class="absolute left-3 top-1/2 -translate-y-1/2 z-50 w-12 h-12 rounded-xl bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
        </button>
      )}

      <!-- Next button -->
      {images.length > 1 && (
        <button data-gallery-next class="absolute right-3 top-1/2 -translate-y-1/2 z-50 w-12 h-12 rounded-xl bg-white/10 hover:bg-white/20 flex items-center justify-center text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </button>
      )}

      <!-- Image container -->
      <div class="w-full h-full flex flex-col items-center justify-center px-16 pt-16 pb-8">
        <div class="relative max-w-5xl w-full flex-1 flex items-center justify-center">
          {images.map((img, i) => (
            <div
              class={`gallery-slide absolute inset-0 flex flex-col items-center justify-center transition-all duration-300 ${i === 0 ? '' : 'opacity-0 pointer-events-none'}`}
              data-slide-index={i}
            >
              <img
                src={img.src}
                alt={img.caption}
                class="max-w-full max-h-[65vh] object-contain rounded-xl shadow-2xl"
                loading={i === 0 ? 'eager' : 'lazy'}
                onerror="this.onerror=null;this.src='/images/tools/placeholder.svg'"
              />
              <p class="mt-4 text-white/80 text-sm text-center max-w-lg">{img.caption}</p>
            </div>
          ))}
        </div>

        <!-- Thumbnail strip -->
        {images.length > 1 && (
          <div class="mt-3 flex items-center gap-2 overflow-x-auto max-w-full py-2 px-4">
            {images.map((img, i) => (
              <button
                data-gallery-thumb={i}
                class={`flex-shrink-0 w-16 h-10 rounded-lg overflow-hidden border-2 transition-all ${i === 0 ? 'border-primary-500 opacity-100' : 'border-transparent opacity-50 hover:opacity-80'}`}
              >
                <img
                  src={img.src}
                  alt=""
                  class="w-full h-full object-cover"
                  loading="lazy"
                  onerror="this.onerror=null;this.src='/images/tools/placeholder.svg'"
                />
              </button>
            ))}
          </div>
        )}


      </div>
    </div>
  </div>
)}

<script>
  document.querySelectorAll('[data-gallery-trigger]').forEach(trigger => {
    const galleryId = trigger.getAttribute('data-gallery-trigger')!;
    const modal = document.getElementById(galleryId)!;
    if (!modal) return;

    // Move modal to body so it escapes any overflow-hidden parents
    document.body.appendChild(modal);

    const slides = modal.querySelectorAll('.gallery-slide') as NodeListOf<HTMLElement>;
    const thumbs = modal.querySelectorAll('[data-gallery-thumb]') as NodeListOf<HTMLElement>;
    const counter = modal.querySelector('[data-gallery-current]') as HTMLElement;
    const prevBtn = modal.querySelector('[data-gallery-prev]') as HTMLElement;
    const nextBtn = modal.querySelector('[data-gallery-next]') as HTMLElement;
    const closeBtn = modal.querySelector('[data-gallery-close]') as HTMLElement;

    let current = 0;
    const total = slides.length;

    function goTo(index: number) {
      if (index < 0) index = total - 1;
      if (index >= total) index = 0;
      slides.forEach((s, i) => {
        if (i === index) {
          s.classList.remove('opacity-0', 'pointer-events-none');
        } else {
          s.classList.add('opacity-0', 'pointer-events-none');
        }
      });
      thumbs.forEach((t, i) => {
        if (i === index) {
          t.classList.add('border-primary-500', 'opacity-100');
          t.classList.remove('border-transparent', 'opacity-50');
        } else {
          t.classList.remove('border-primary-500', 'opacity-100');
          t.classList.add('border-transparent', 'opacity-50');
        }
      });
      if (counter) counter.textContent = String(index + 1);
      current = index;
    }

    function open() {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
      goTo(0);
    }

    function close() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    }

    trigger.addEventListener('click', open);
    closeBtn?.addEventListener('click', close);
    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));

    thumbs.forEach((thumb, i) => {
      thumb.addEventListener('click', () => goTo(i));
    });

    modal.addEventListener('click', (e) => {
      if (e.target === modal) close();
    });

    document.addEventListener('keydown', (e) => {
      if (modal.classList.contains('hidden')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') goTo(current - 1);
      if (e.key === 'ArrowRight') goTo(current + 1);
    });
  });
</script>
